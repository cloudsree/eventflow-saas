generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  imageUrl     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships  Membership[]
  sentMessages Message[]    @relation("SentMessages")
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]
  events        Event[]
  vendors       Vendor[]
  subscription  Subscription?
}

model Membership {
  id              String        @id @default(cuid())
  userId          String
  organizationId  String
  role            Role
  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

enum Role {
  OWNER
  ADMIN
  PLANNER
  STAFF
  VENDOR
  CLIENT
  GUEST
}

model Event {
  id              String          @id @default(cuid())
  organizationId  String
  name            String
  type            EventType
  status          EventStatus     @default(DRAFT)
  description     String?
  publicSlug      String?         @unique
  startDate       DateTime
  endDate         DateTime?
  location        String?
  timezone        String          @default("America/New_York")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id])

  guests          Guest[]
  vendors         Vendor[]
  tasks           Task[]
  budgetItems     BudgetItem[]
  scheduleItems   ScheduleItem[]
  tables          SeatingTable[]
  messages        Message[]
  files           FileAsset[]
}

enum EventType {
  WEDDING
  CONFERENCE
  CONVENTION
  CORPORATE
  SOCIAL
  OTHER
}

enum EventStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Guest {
  id               String        @id @default(cuid())
  eventId          String
  firstName        String
  lastName         String?
  email            String?
  phone            String?
  partyName        String?
  rsvpToken        String?       @unique
  rsvpStatus       RSVPStatus    @default(PENDING)
  mealPreference   String?
  dietaryNotes     String?
  notes            String?
  plusOneAllowed   Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  event            Event         @relation(fields: [eventId], references: [id])

  rsvp             RSVP?
  seat             Seat?
}

enum RSVPStatus {
  PENDING
  ACCEPTED
  DECLINED
  MAYBE
}

model RSVP {
  id            String        @id @default(cuid())
  guestId       String        @unique
  response      RSVPStatus
  submittedAt   DateTime      @default(now())
  answers       Json?

  guest         Guest         @relation(fields: [guestId], references: [id])
}

model Vendor {
  id               String          @id @default(cuid())
  organizationId   String
  eventId          String?
  name             String
  category         VendorCategory
  contactName      String?
  email            String?
  phone            String?
  website          String?
  contractUrl      String?
  paymentStatus    PaymentStatus   @default(NOT_STARTED)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization     Organization    @relation(fields: [organizationId], references: [id])
  event            Event?          @relation(fields: [eventId], references: [id])
}

enum VendorCategory {
  VENUE
  CATERING
  PHOTOGRAPHY
  VIDEOGRAPHY
  FLORIST
  MUSIC
  DECOR
  AV
  SECURITY
  TRANSPORTATION
  OTHER
}

enum PaymentStatus {
  NOT_STARTED
  DEPOSIT_PAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

model Task {
  id             String       @id @default(cuid())
  eventId        String
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       Priority     @default(MEDIUM)
  dueDate        DateTime?
  assignedToId   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  event          Event        @relation(fields: [eventId], references: [id])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model BudgetItem {
  id                String      @id @default(cuid())
  eventId           String
  category          String
  name              String
  estimatedAmount   Decimal
  actualAmount      Decimal?
  paidAmount        Decimal?
  vendorId          String?
  notes             String?
  createdAt         DateTime    @default(now())

  event             Event       @relation(fields: [eventId], references: [id])
}

model ScheduleItem {
  id              String               @id @default(cuid())
  eventId         String
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime?
  location        String?
  visibility      ScheduleVisibility   @default(INTERNAL)
  createdAt       DateTime             @default(now())

  event           Event                @relation(fields: [eventId], references: [id])
}

enum ScheduleVisibility {
  INTERNAL
  VENDOR
  PUBLIC
}

model SeatingTable {
  id             String       @id @default(cuid())
  eventId        String
  name           String
  capacity       Int
  xPosition      Float?
  yPosition      Float?
  shape          TableShape   @default(ROUND)

  event          Event        @relation(fields: [eventId], references: [id])

  seats          Seat[]
}

enum TableShape {
  ROUND
  RECTANGLE
  SQUARE
}

model Seat {
  id            String         @id @default(cuid())
  tableId       String
  guestId       String?        @unique
  seatNumber    Int

  table         SeatingTable   @relation(fields: [tableId], references: [id])
  guest         Guest?         @relation(fields: [guestId], references: [id])
}

model Message {
  id               String            @id @default(cuid())
  eventId          String
  senderId         String?
  channel          MessageChannel
  subject          String?
  body             String
  recipientGroup   String?
  sentAt           DateTime?
  createdAt        DateTime          @default(now())

  event            Event             @relation(fields: [eventId], references: [id])
  sender           User?             @relation("SentMessages", fields: [senderId], references: [id])
}

enum MessageChannel {
  EMAIL
  SMS
  IN_APP
}

model FileAsset {
  id            String       @id @default(cuid())
  eventId       String
  name          String
  url           String
  mimeType      String
  size          Int
  uploadedAt    DateTime     @default(now())

  event         Event        @relation(fields: [eventId], references: [id])
}

model Subscription {
  id                      String                @id @default(cuid())
  organizationId          String                @unique
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  plan                    Plan
  status                  SubscriptionStatus
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  organization            Organization          @relation(fields: [organizationId], references: [id])
}

enum Plan {
  FREE
  STARTER
  PRO
 BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model AuditLog {
  id               String      @id @default(cuid())
  organizationId   String
  userId           String?
  action           String
  entityType       String
  entityId         String
  metadata         Json?
  createdAt        DateTime    @default(now())
}